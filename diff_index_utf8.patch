+// Safe Storage Helpers to prevent ReferenceError/SecurityError in sandbox environments or during Electron startup
+const safeGetItem = (key: string, isLocal = false) => {
+  try {
+    if (typeof window === 'undefined') return null;
+    const storage = isLocal ? window.localStorage : window.sessionStorage;
+    return storage ? storage.getItem(key) : null;
+  } catch (e) {
+    console.warn("Storage access failed", e);
+    return null;
+  }
+};
+
+const safeSetItem = (key: string, value: string, isLocal = false) => {
+  try {
+    if (typeof window === 'undefined') return;
+    const storage = isLocal ? window.localStorage : window.sessionStorage;
+    if (storage) storage.setItem(key, value);
+  } catch (e) {
+    console.warn("Storage access failed", e);
+  }
+};
+
+const safeRemoveItem = (key: string, isLocal = false) => {
+  try {
+    if (typeof window === 'undefined') return;
+    const storage = isLocal ? window.localStorage : window.sessionStorage;
+    if (storage) storage.removeItem(key);
+  } catch (e) {
+    console.warn("Storage access failed", e);
+  }
+};
+
+const getApiHost = () => safeGetItem('np_server_ip', true) || window.location.hostname || '127.0.0.1';
+
+type Step = 'upload' | 'map' | 'clean' | 'results';
+
+const analyzeGstinIssues = (pr: InvoiceRecord[], tb: InvoiceRecord[]): GstinIssue[] => {
+  const issues: GstinIssue[] = [];
+  const prNameMap = new Map<string, Set<string>>();
+  const prGstinMap = new Map<string, Set<string>>();
+  const tbNameMap = new Map<string, Set<string>>();
+  const tbNormNameMap = new Map<string, Set<string>>();
+  const tbGstinToNameMap = new Map<string, string>();
+
+  tb.forEach(r => {
+    if (!r.supplierName) return;
+    const gstin = normalizeGstin(r.gstin);
+    if (!tbNameMap.has(r.supplierName)) tbNameMap.set(r.supplierName, new Set());
+    tbNameMap.get(r.supplierName)!.add(gstin);
+
+    const norm = normalizePartyName(r.supplierName);
+    if (!tbNormNameMap.has(norm)) tbNormNameMap.set(norm, new Set());
+    tbNormNameMap.get(norm)!.add(gstin);
+
+    if (gstin) tbGstinToNameMap.set(gstin, r.supplierName);
+  });
+
+  pr.forEach(r => {
+    if (!r.supplierName) return;
+    const gstin = normalizeGstin(r.gstin);
+    if (!prNameMap.has(r.supplierName)) prNameMap.set(r.supplierName, new Set());
+    prNameMap.get(r.supplierName)!.add(gstin);
+
+    if (gstin) {
+      if (!prGstinMap.has(gstin)) prGstinMap.set(gstin, new Set());
+      prGstinMap.get(gstin)!.add(r.supplierName);
+    }
+  });
+
+  prNameMap.forEach((gstins, name) => {
+    const norm = normalizePartyName(name);
+    const tbGstins = tbNameMap.get(name) || tbNormNameMap.get(norm);
+    const suggested = tbGstins && tbGstins.size > 0 ? Array.from(tbGstins).find(g => g !== '') : undefined;
+    const suggestedName = suggested ? tbGstinToNameMap.get(suggested) : undefined;
+
+    if (gstins.has('')) {
+      issues.push({
+        id: `missing-${name}`, supplierName: name, source: 'PR',
+        originalGstin: '', currentGstin: '', suggestedGstin: suggested,
+        suggestedName,
+        issueType: 'Missing GSTIN'
+      });
+    }
+
+    gstins.forEach(g => {
+      if (g && tbGstins && tbGstins.size > 0 && !tbGstins.has(g)) {
+        issues.push({
+          id: `mismatch-${name}-${g}`, supplierName: name, source: 'PR',
+          originalGstin: g, currentGstin: g, suggestedGstin: suggested,
+          suggestedName,
+          issueType: 'GSTIN Mismatch vs Govt'
+        });
+      }
+    });
+  });
+
+  prGstinMap.forEach((names, gstin) => {
+    if (names.size > 1) {
+      names.forEach(name => {
+        const norm = normalizePartyName(name);
+        const tbGstins = tbNameMap.get(name) || tbNormNameMap.get(norm);
+        const suggested = tbGstins && tbGstins.size > 0 ? Array.from(tbGstins).find(g => g !== '') : undefined;
+        const suggestedName = suggested ? tbGstinToNameMap.get(suggested) : undefined;
+
+        issues.push({
+          id: `dup-${gstin}-${name}`, supplierName: name, source: 'PR',
+          originalGstin: gstin, currentGstin: gstin,
+          suggestedGstin: suggested && suggested !== gstin ? suggested : undefined,
+          suggestedName: suggested && suggested !== gstin ? suggestedName : undefined,
+          issueType: 'Duplicate GSTIN',
+          relatedParties: Array.from(names).filter(n => n !== name)
+        });
+      });
+    }
+  });
+
+  const uniqueIssues: GstinIssue[] = [];
+  const seen = new Set<string>();
+  for (const i of issues) { if (!seen.has(i.id)) { seen.add(i.id); uniqueIssues.push(i); } }
+  return uniqueIssues;
+};
